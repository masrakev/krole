# Ollama — LLM + embeddings runtime (accessible via the docker network)
OLLAMA_BASE_URL=http://ollama:11434

# Chroma — vector store (internal docker network port is 8000; host-mapped to 8001)
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Models
MISTRAL_MODEL=mistral
EMBED_MODEL=bge-m3

# Fournisseur LLM — GÉNÉRATION uniquement : mistral (local, défaut) | gemini | claude.
# Choix EXPLICITE : une clé renseignée ne bascule JAMAIS le moteur toute seule.
# Cloud choisi sans clé → avertissement au démarrage + repli sur Mistral local.
# Embeddings (bge-m3) et reranker restent 100 % locaux dans tous les cas.
LLM_PROVIDER=mistral
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-opus-4-8

# Inférence Ollama (CPU-only). NUM_THREAD = nb de cœurs PHYSIQUES de la machine.
NUM_THREAD=8
NUM_CTX=2048
KEEP_ALIVE=30m

# RAG — hybrid retrieval + rerank
K_CANDIDATES=8
TOP_K=4
# Blocs réellement injectés dans le prompt (≤ TOP_K) + plafond de chars/bloc :
# limite la taille du prompt, donc le temps d'évaluation CPU.
CONTEXT_K=3
CONTEXT_CHAR_CAP=500
NUM_PREDICT=96
# Rerank désactivé par défaut (profil démo) : -20 s/requête et -2,3 Go de RAM.
# Mettre à true pour réactiver le cross-encoder (+ le garde-fou de pertinence).
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_THRESHOLD=0.3
REWRITE_NUM_PREDICT=32

# Mode vocal (100 % local, CPU) — modèles PETITS, mis en cache dans /models.
STT_MODEL=small
STT_COMPUTE_TYPE=int8
# Langue forcée pour la transcription (ex. fr) ; vide = détection automatique.
STT_LANGUAGE=
TTS_VOICE=fr_FR-siwis-medium

# Évaluation RAGAS — juge = Mistral via Ollama, embeddings = bge-m3 (PAS d'OpenAI).
EVAL_JUDGE_MODEL=mistral
EVAL_JUDGE_NUM_PREDICT=256
EVAL_NUM_CTX=4096
# Délai max par métrique et par question (s) avant de l'ignorer (CPU lent).
EVAL_METRIC_TIMEOUT=300

# Frontend (build) — URL du backend atteinte par le navigateur.
VITE_API_BASE_URL=http://localhost:8000
